generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPANY
  AGENT
}

enum Status {
  PENDING_KYC
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  phone        String @unique
  passwordHash String
  role         Role   @default(AGENT)
  status       Status @default(PENDING_KYC)
  inviteCode   String @unique

  referredById String?
  referredBy   User?   @relation("NetworkTree", fields: [referredById], references: [id])
  upline       User[]  @relation("NetworkTree")

  kyc    Kyc?
  wallet Wallet?

  properties        Property[]
  agentVisits       Visit[]             @relation("AgentVisits")
  dealsClosed       Deal[]              @relation("ClosingAgent")
  leads             Lead[]              @relation("AgentLeads")
  withdrawalRequests WithdrawalRequest[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kyc {
  id            String  @id @default(uuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id])
  aadhaarNumber String? @unique
  panNumber     String? @unique
  idFrontUrl    String?
  idBackUrl     String?
  addressDocUrl String?
  selfieUrl     String?
  isVerified    Boolean @default(false)
  verifiedAt    DateTime?
  rejectionReason String?

  // Bank Info stored with KYC context
  bankName      String?
  accountNumber String?
  ifscCode      String?
  accountName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PropertyStatus {
  PENDING_APPROVAL
  AVAILABLE
  SOLD
  REJECTED
  INACTIVE
}

enum ProjectType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
}

enum ProjectStage {
  UPCOMING
  UNDER_CONSTRUCTION
  READY_TO_MOVE
}

enum LeadStage {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  VISIT_DONE
  NEGOTIATING
  DEAL_CLOSED
  LOST
}

model LeadInterestedProperty {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation("LeadInterests", fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation("PropertyLeadInterests", fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([leadId, propertyId])
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Float    // Default/Min Price
  maxPrice    Float?
  currency    Currency @default(INR)

  // Project Info
  projectType  ProjectType  @default(APARTMENT)
  projectStage ProjectStage @default(UPCOMING)
  reraId       String?
  launchDate   DateTime?
  possessionDate  DateTime?

  // Location
  country      String?
  state        String?
  city         String?
  locality     String?
  address      String?
  pincode      String?
  latitude     Float?
  longitude    Float?

  // Additional Pricing
  pricePerSqFt      Float?
  bookingAmount     Float?
  maintenanceCharge Float?

  // Builder Info
  builderName    String?
  builderContact String?
  builderEmail   String?
  builderAddress String?

  // Media & Settings
  images    Json?  // Array of image URLs
  amenities Json?  // ["pool", "gym", ...]
  seoTags   Json?
  
  visitAvailability Json?
  approvalType      String? @default("AUTO")

  companyId String
  company   User           @relation(fields: [companyId], references: [id])
  status    PropertyStatus @default(PENDING_APPROVAL)
  
  commissionPoolPct Float @default(2.0)

  // Relations
  units   UnitType[]
  documents PropertyDocument[]
  visits  Visit[]
  deals   Deal[]
  leads   Lead[]     @relation("LeadProperty")
  leadInterests LeadInterestedProperty[] @relation("PropertyLeadInterests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UnitType {
  id         String @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  name       String  // e.g. "3BHK Premium"
  beds       Int
  baths      Int
  balconies  Int?
  superArea  Float
  carpetArea Float
  minPrice   Float
  maxPrice   Float?
  totalUnits Int
  availableUnits Int
}

model PropertyDocument {
  id         String @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  type       String  // "BROCHURE", "FLOOR_PLAN", "LEGAL"
  url        String
  title      String?

  createdAt DateTime @default(now())
}

model Lead {
  id         String    @id @default(uuid())
  agentId    String
  agent      User      @relation("AgentLeads", fields: [agentId], references: [id])

  buyerName  String
  buyerPhone String
  buyerEmail String?
  budget     Float?

  preferredCity  String?
  preferredType  String?
  notes          String?

  stage      LeadStage @default(NEW)

  // Primary interested property (quick reference)
  propertyId String?
  property   Property? @relation("LeadProperty", fields: [propertyId], references: [id])

  // Additional interested properties
  interestedProperties LeadInterestedProperty[] @relation("LeadInterests")

  // Visits scheduled for this lead
  leadVisits Visit[] @relation("LeadVisits")

  // Closure info
  closedReason String?
  closedPrice  Float?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum VisitStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Visit {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  agentId String
  agent   User   @relation("AgentVisits", fields: [agentId], references: [id])

  leadId  String?
  lead    Lead?  @relation("LeadVisits", fields: [leadId], references: [id])

  clientName  String
  clientPhone String
  scheduledAt DateTime
  status      VisitStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  agentId String
  agent   User   @relation("ClosingAgent", fields: [agentId], references: [id])

  salePrice       Float
  totalCommission Float
  currency        Currency @default(INR)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id       String   @id @default(uuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id])
  balance  Float    @default(0.0)
  currency Currency @default(INR)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TxType {
  CREDIT
  DEBIT
}

model Transaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id])

  amount      Float
  currency    Currency @default(INR)
  type        TxType
  description String

  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model GlobalConfig {
  id           String @id @default("DEFAULT")
  commissionPoolPct Float @default(2.0)
  agentSplitPct    Float @default(80.0)
  networkPoolPct   Float @default(15.0)
  companySplitPct  Float @default(5.0)
  
  tierSplits Json // Array of percentages e.g. [40, 25, 15, 10, 10]
  
  brandingLogoUrl String?
  brandingEmoji   String @default("🏢")
  
  updatedAt DateTime @updatedAt
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  amount        Float
  status        WithdrawalStatus @default(PENDING)

  // Payout details (copied from KYC at time of request)
  bankName      String?
  accountNumber String?
  ifscCode      String?
  accountName   String?
  upiId         String?

  adminNote     String?
  processedAt   DateTime?
  processedBy   String?   // admin userId

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyInvite {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String?   // pre-fill if known
  note      String?   // e.g. company name hint
  createdBy String    // admin userId
  usedAt    DateTime?
  usedBy    String?   // company userId after registration
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String   // e.g. "PROPERTY", "DEAL", "CONFIG"
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?

  createdAt DateTime @default(now())
}

enum AccessRequestStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model AccessRequest {
  id         String              @id @default(uuid())
  fullName   String
  email      String
  phone      String
  experience String              // e.g. "0-2 Years", "3-5 Years", "5+ Years"
  status     AccessRequestStatus @default(PENDING)
  adminNote  String?
  reviewedAt DateTime?
  reviewedBy String?             // admin userId
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

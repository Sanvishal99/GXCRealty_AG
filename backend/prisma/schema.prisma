generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  phone              String              @unique
  passwordHash       String
  role               Role                @default(AGENT)
  status             Status              @default(PENDING_KYC)
  inviteCode         String              @unique
  referredById       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  dealsClosed        Deal[]              @relation("ClosingAgent")
  kyc                Kyc?
  leads              Lead[]              @relation("AgentLeads")
  receivedMessages   Message[]           @relation("ReceivedMessages")
  sentMessages       Message[]           @relation("SentMessages")
  properties         Property[]
  referredBy         User?               @relation("NetworkTree", fields: [referredById], references: [id])
  upline             User[]              @relation("NetworkTree")
  agentVisits        Visit[]             @relation("AgentVisits")
  wallet             Wallet?
  withdrawalRequests WithdrawalRequest[]
}

model Kyc {
  id              String    @id @default(uuid())
  userId          String    @unique
  aadhaarNumber   String?   @unique
  panNumber       String?   @unique
  idFrontUrl      String?
  idBackUrl       String?
  addressDocUrl   String?
  selfieUrl       String?
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  rejectionReason String?
  bankName        String?
  accountNumber   String?
  ifscCode        String?
  accountName     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
}

model LeadInterestedProperty {
  id         String   @id @default(uuid())
  leadId     String
  propertyId String
  createdAt  DateTime @default(now())
  lead       Lead     @relation("LeadInterests", fields: [leadId], references: [id], onDelete: Cascade)
  property   Property @relation("PropertyLeadInterests", fields: [propertyId], references: [id])

  @@unique([leadId, propertyId])
}

model Property {
  id                String                   @id @default(uuid())
  title             String
  description       String?
  price             Float
  maxPrice          Float?
  currency          Currency                 @default(INR)
  projectType       ProjectType              @default(APARTMENT)
  projectStage      ProjectStage             @default(UPCOMING)
  reraId            String?
  launchDate        DateTime?
  possessionDate    DateTime?
  country           String?
  state             String?
  city              String?
  locality          String?
  address           String?
  pincode           String?
  latitude          Float?
  longitude         Float?
  pricePerSqFt      Float?
  bookingAmount     Float?
  maintenanceCharge Float?
  builderName       String?
  builderContact    String?
  builderEmail      String?
  builderAddress    String?
  images            Json?
  amenities         Json?
  seoTags           Json?
  visitAvailability Json?
  approvalType      String?                  @default("AUTO")
  companyId         String
  status            PropertyStatus           @default(PENDING_APPROVAL)
  commissionPoolPct Float                    @default(2.0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deals             Deal[]
  leads             Lead[]                   @relation("LeadProperty")
  leadInterests     LeadInterestedProperty[] @relation("PropertyLeadInterests")
  company           User                     @relation(fields: [companyId], references: [id])
  documents         PropertyDocument[]
  units             UnitType[]
  visits            Visit[]
}

model UnitType {
  id             String   @id @default(uuid())
  propertyId     String
  name           String
  beds           Int
  baths          Int
  balconies      Int?
  superArea      Float
  carpetArea     Float
  minPrice       Float
  maxPrice       Float?
  totalUnits     Int
  availableUnits Int
  property       Property @relation(fields: [propertyId], references: [id])
}

model PropertyDocument {
  id         String   @id @default(uuid())
  propertyId String
  type       String
  url        String
  title      String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
}

model Lead {
  id                   String                   @id @default(uuid())
  agentId              String
  buyerName            String
  buyerPhone           String
  buyerEmail           String?
  budget               Float?
  preferredCity        String?
  preferredType        String?
  notes                String?
  stage                LeadStage                @default(NEW)
  propertyId           String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  closedPrice          Float?
  closedReason         String?
  agent                User                     @relation("AgentLeads", fields: [agentId], references: [id])
  property             Property?                @relation("LeadProperty", fields: [propertyId], references: [id])
  interestedProperties LeadInterestedProperty[] @relation("LeadInterests")
  leadVisits           Visit[]                  @relation("LeadVisits")
}

model Visit {
  id          String      @id @default(uuid())
  propertyId  String
  agentId     String
  clientName  String
  clientPhone String
  scheduledAt DateTime
  status      VisitStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  leadId      String?
  agent       User        @relation("AgentVisits", fields: [agentId], references: [id])
  lead        Lead?       @relation("LeadVisits", fields: [leadId], references: [id])
  property    Property    @relation(fields: [propertyId], references: [id])
}

model Deal {
  id              String        @id @default(uuid())
  propertyId      String
  agentId         String
  salePrice       Float
  totalCommission Float
  currency        Currency      @default(INR)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  agent           User          @relation("ClosingAgent", fields: [agentId], references: [id])
  property        Property      @relation(fields: [propertyId], references: [id])
  transactions    Transaction[]
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Float         @default(0.0)
  currency     Currency      @default(INR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  walletId    String
  dealId      String?
  amount      Float
  currency    Currency @default(INR)
  type        TxType
  description String
  createdAt   DateTime @default(now())
  deal        Deal?    @relation(fields: [dealId], references: [id])
  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  mentions   Json?
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model GlobalConfig {
  id                String   @id @default("DEFAULT")
  commissionPoolPct Float    @default(2.0)
  agentSplitPct     Float    @default(80.0)
  networkPoolPct    Float    @default(15.0)
  companySplitPct   Float    @default(5.0)
  tierSplits        Json
  brandingLogoUrl   String?
  brandingEmoji     String   @default("🏢")
  updatedAt         DateTime @updatedAt
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  userId        String
  amount        Float
  status        WithdrawalStatus @default(PENDING)
  bankName      String?
  accountNumber String?
  ifscCode      String?
  accountName   String?
  upiId         String?
  adminNote     String?
  processedAt   DateTime?
  processedBy   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id])
}

model CompanyInvite {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String?
  note      String?
  createdBy String
  usedAt    DateTime?
  usedBy    String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model AccessRequest {
  id         String              @id @default(uuid())
  fullName   String
  email      String
  phone      String
  experience String
  status     AccessRequestStatus @default(PENDING)
  adminNote  String?
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

enum Role {
  ADMIN
  COMPANY
  AGENT
}

enum Status {
  PENDING_KYC
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

enum PropertyStatus {
  PENDING_APPROVAL
  AVAILABLE
  SOLD
  REJECTED
  INACTIVE
}

enum ProjectType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
}

enum ProjectStage {
  UPCOMING
  UNDER_CONSTRUCTION
  READY_TO_MOVE
}

enum LeadStage {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  VISIT_DONE
  NEGOTIATING
  DEAL_CLOSED
  LOST
}

enum VisitStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum TxType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum AccessRequestStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

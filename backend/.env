# --------------------------------------------------------------------------
# SUPABASE DATABASE CONFIGURATION (PRISMA + POSTGRESQL)
# --------------------------------------------------------------------------
# 1. DATABASE_URL: Transaction Pooler connection string (Port 6543)
#    Required: Append "?pgbouncer=true&connection_limit=1" for Prisma.
DATABASE_URL="postgresql://postgres.jiaytcczdlpkvauvbxmm:Sanvishal%2A426858@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20"

# 2. DIRECT_URL: Direct Session connection string (Port 5432)
#    Required for running `npx prisma db push` or migrations securely.
DIRECT_URL="postgresql://postgres.jiaytcczdlpkvauvbxmm:Sanvishal%2A426858@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# JWT Auth
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_MIN_32_CHARS"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000
FRONTEND_URL="http://localhost:3001"

